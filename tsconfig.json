{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "types": ["node"],

    "sourceMap": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "noUncheckedIndexedAccess": true,

    "isolatedModules": true,

    "skipLibCheck": true
  },

  "include": ["src"],

  "exclude": ["node_modules", "dist"]
}